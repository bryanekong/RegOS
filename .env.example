# Supabase (all services)
SUPABASE_DB_URL=postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL_SYNC=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=policies

# Railway API
API_KEY=regos-proto-2026
POLL_INTERVAL_SECONDS=600

# Vercel (set these in Vercel dashboard env vars, prefix VITE_)
VITE_API_BASE_URL=https://your-api.railway.app
VITE_SUPABASE_URL=https://[ref].supabase.co
VITE_SUPABASE_ANON_KEY=
